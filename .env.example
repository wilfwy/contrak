# Port du serveur
PORT=3000

# URL du frontend (pour les redirections)
FRONTEND_URL=http://localhost:3000

# Firebase Configuration
# TÃ©lÃ©chargez votre fichier service account depuis Firebase Console
# et placez-le dans config/firebase-service-account.json
# OU utilisez la variable d'environnement ci-dessous :
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Node Environment
NODE_ENV=production

# SMTP Configuration (for emails - order confirmation, password reset, etc.)
# Use https://ethereal.email for testing (no real delivery)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@ethereal.email
SMTP_PASS=your-ethereal-password
SMTP_FROM=noreply@contrak.io

# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-api03-...
